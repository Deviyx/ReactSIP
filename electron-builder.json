{
  "appId": "com.reactsip.desktop",
  "productName": "ReactSIP",
  "directories": {
    "buildResources": "public",
    "output": "release"
  },
  "files": [
    "renderer-dist/**/*",
    "public/electron.js",
    "public/preload.js",
    "package.json",
    "node_modules/**/*"
  ],
  "extraResources": [
    {
      "from": "native/sip-agent/bin",
      "to": "native",
      "filter": [
        "sip-agent.exe"
      ]
    }
  ],
  "win": {
    "target": ["nsis", "portable"]
  },
  "publish": [
    {
      "provider": "github",
      "owner": "Deviyx",
      "repo": "ReactSIP",
      "releaseType": "release"
    }
  ],
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
